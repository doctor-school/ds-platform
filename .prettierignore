# Generated lockfiles — never reformat. The lockfile serializer (pnpm) owns the
# layout; running Prettier over it produces an enormous, meaningless diff and
# fights Dependabot, which regenerates it in pnpm's native style with no local
# hooks. Keeping it out of Prettier keeps lock diffs to the actual dependency
# delta. (lint-staged globs *.yaml, so this exclusion is what spares the lock.)
pnpm-lock.yaml

# Build / generated output (already gitignored, listed for any ad-hoc runs).
**/.next/**
**/dist/**
**/.source/**
**/coverage/**

# Generated design tokens (#233). Style Dictionary owns this layout; the CI
# `tokens-fresh` guard regenerates and `git diff --exit-code`s them, so Prettier
# must NOT touch them or the committed file would diverge from a fresh build.
packages/design-system/src/styles/tokens.css
packages/design-system/src/styles/allowed-tokens.json

