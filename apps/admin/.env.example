# Admin app (007 event-admin). Reuses the shipped 003 auth via the same-origin
# `/v1/*` proxy — no admin-local secrets. The proxy upstream is the running api.
#
# Local dev-stand run (single-session default; parallel sessions probe a free
# port with `pnpm dev:ports` and set API_PROXY_TARGET to that api):
API_PROXY_TARGET=http://localhost:3000

# The admin dev server binds :3200 by default (see package.json `dev`/`start`).
# Override with `pnpm exec next dev -p <port>` for a parallel session.
