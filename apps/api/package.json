{
  "name": "@ds/api",
  "version": "0.18.4",
  "private": true,
  "type": "module",
  "description": "DS Platform backend API — NestJS 11 + Fastify (ADR-0002).",
  "main": "dist/main.js",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "build:smoke": "node scripts/build-smoke.mjs",
    "start": "node dist/main.js",
    "reconcile:sweep": "tsx scripts/reconcile-sweep.ts",
    "presence:export": "tsx scripts/presence-export.ts",
    "seed:events": "tsx scripts/seed-events.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "drizzle:generate": "drizzle-kit generate --config ../../packages/db/drizzle.config.ts",
    "drizzle:migrate": "pnpm -w run dev:snapshot pre-mig-auto && drizzle-kit migrate --config ../../packages/db/drizzle.config.ts",
    "drizzle:migrate:ci": "drizzle-kit migrate --config ../../packages/db/drizzle.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@ds/db": "workspace:*",
    "@ds/schemas": "workspace:*",
    "@fastify/multipart": "^10.1.0",
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-fastify": "^11.1.28",
    "@nestjs/schedule": "^6.1.3",
    "@sentry/node": "^10.65.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.10.0",
    "ioredis": "^5.11.1",
    "nestjs-zod": "^5.4.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "unleash-client": "^6.11.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.24",
    "@nestjs/testing": "^11.1.28",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "supertest": "^7.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
