{
  "name": "@ds/api",
  "version": "0.11.0",
  "private": true,
  "type": "module",
  "description": "DS Platform backend API — NestJS 11 + Fastify (ADR-0002).",
  "main": "dist/main.js",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "build:smoke": "node scripts/build-smoke.mjs",
    "start": "node dist/main.js",
    "reconcile:sweep": "tsx scripts/reconcile-sweep.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "drizzle:generate": "drizzle-kit generate --config ../../packages/db/drizzle.config.ts",
    "drizzle:migrate": "pnpm -w run dev:snapshot pre-mig-auto && drizzle-kit migrate --config ../../packages/db/drizzle.config.ts",
    "drizzle:migrate:ci": "drizzle-kit migrate --config ../../packages/db/drizzle.config.ts"
  },
  "dependencies": {
    "@ds/db": "workspace:*",
    "@ds/schemas": "workspace:*",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-fastify": "^11.1.27",
    "@nestjs/schedule": "^6.1.3",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.9.0",
    "ioredis": "^5.11.1",
    "nestjs-zod": "^5.4.0",
    "nodemailer": "^9.0.1",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "unleash-client": "^6.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/testing": "^11.1.27",
    "@types/node": "^25.9.3",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "supertest": "^7.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
