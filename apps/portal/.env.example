# Portal environment (copy to .env.local; NEXT_PUBLIC_* are inlined at build).

# Yandex SmartCaptcha CLIENT key — the public half of the keypair (003 #84).
# Unset ⇒ the BotProtectionField renders an inactive placeholder and the portal
# still builds; set it to render the live widget. The SERVER key lives in the
# API env (SMARTCAPTCHA_SERVER_KEY), never here.
NEXT_PUBLIC_SMARTCAPTCHA_SITE_KEY=
