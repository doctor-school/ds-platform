# Portal (Next.js) — user-facing auth screens.
app.doctor.school {
	reverse_proxy portal:3000
}

# NestJS BFF/API.
api.doctor.school {
	reverse_proxy api:3000 # TODO(DSO-100): confirm the api's listen port
}

# Zitadel OIDC issuer — single-origin split: Login V2 UI vs core (dev-stand idp-proxy pattern).
id.doctor.school {
	# Login V2 UI paths → the login container.
	handle /ui/v2/login/* {
		reverse_proxy zitadel-login:3000 # TODO(DSO-100): confirm login container port
	}
	# Everything else → Zitadel core (gRPC-web/HTTP2).
	handle {
		reverse_proxy zitadel:8080 # TODO(DSO-100): confirm core port + h2c if needed
	}
}
