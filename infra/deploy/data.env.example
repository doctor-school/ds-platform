# /etc/ds-platform/data.env — TEMPLATE (DSO-100 spec §5.4, §6.3). Copy onto
# data-prod as /etc/ds-platform/data.env, root:root 0600. NEVER commit real values.
# Consumed by the `postgres` (POSTGRES_PASSWORD + PGBACKREST_* for archive_command)
# and `pgbackrest` (all PGBACKREST_*) services (compose/data-prod/compose.yml).
#
# The `ds` password below MUST equal the password in api.env's DATABASE_URL and the
# ZITADEL_DATABASE_*_PASSWORD in zitadel.env (one Postgres role, `ds`).

# === Postgres superuser (`ds`) password ===
POSTGRES_PASSWORD=<db-password>

# === pgbackrest repo → Timeweb S3 (spec §6.3) ===
# Non-secret repo policy (type/retention/cipher-type/stanza) is in the committed
# pgbackrest.conf; these deploy-specific + secret values inject via the PGBACKREST_*
# env. Bucket/endpoint/region come from `terraform output` (run in infra/deploy/
# terraform/ after apply):
#   PGBACKREST_REPO1_S3_BUCKET      <- terraform output -raw pgbackrest_bucket_full_name
#   PGBACKREST_REPO1_S3_ENDPOINT    <- terraform output -raw pgbackrest_s3_hostname
#   PGBACKREST_REPO1_S3_KEY         <- terraform output -raw pgbackrest_s3_access_key   (DD-6: from tfstate)
#   PGBACKREST_REPO1_S3_KEY_SECRET  <- terraform output -raw pgbackrest_s3_secret_key   (DD-6: from tfstate)
PGBACKREST_REPO1_S3_BUCKET=<bucket-full-name>
PGBACKREST_REPO1_S3_ENDPOINT=<s3-hostname>
PGBACKREST_REPO1_S3_REGION=ru-1
PGBACKREST_REPO1_S3_KEY=<s3-access-key>
PGBACKREST_REPO1_S3_KEY_SECRET=<s3-secret-key>

# === Repo cipher passphrase — AES-256-CBC (spec §6.3). Encrypts backups + WAL at
# rest in S3. Generate once, keep stable (a rotated pass can't read old backups):
#   openssl rand -hex 32
# Vault-light interim → Vault KEK later (ADR-0003 §2.4 follow-up).
PGBACKREST_REPO1_CIPHER_PASS=<openssl-rand-hex-32>
