# /etc/ds-platform/glitchtip.env — GlitchTip error-monitoring secrets (DSO-125).
# data-prod, root:root 0600. Copy to /etc/ds-platform/glitchtip.env and fill REAL
# values. NEVER committed. Consumed by infra/deploy/compose/data-prod/glitchtip/compose.yml.
#
#   sudo install -d -m 700 /etc/ds-platform
#   sudo install -m 600 ~/ds-platform/infra/deploy/glitchtip.env.example /etc/ds-platform/glitchtip.env
#   # …then edit to fill the REAL values below.

# Django secret — any long random string. Generate with: openssl rand -hex 32
SECRET_KEY=<openssl-rand-hex-32>

# GlitchTip's own database in the EXISTING data-prod Postgres 17. A NEW database +
# role (`glitchtip`), created by hand before first `up` (README §GlitchTip), reached
# over the VPC interface (same host the api uses). Password = the glitchtip role's
# own password (NOT the `ds` cluster password — GlitchTip gets its own least-priv role).
DATABASE_URL=postgres://glitchtip:<glitchtip-db-password>@192.168.0.10:5432/glitchtip

# Public URL the UI is served at. The UI is NOT internet-published; the owner reaches
# it via an SSH tunnel (README), so this is the tunnel-local origin. Change if the
# tunnel maps a different local port.
GLITCHTIP_DOMAIN=http://localhost:8000

# Alert/notification email transport. Default = console (events still ingest; alert
# emails are printed to the container log, no external send). To wire the mail.ru relay
# (reference_doctor_school_email_dns) for real alert emails (DSO-132, live-verified):
#   EMAIL_URL=smtp+ssl://noreply%40doctor.school:<app-password>@smtp.mail.ru:465
#   DEFAULT_FROM_EMAIL=noreply@doctor.school
# NOTE the scheme: port 465 is implicit-SSL (SMTPS), so it needs `smtp+ssl://`
# (django-environ → EMAIL_USE_SSL=True). Plain `smtp://` on 465 sets neither TLS nor
# SSL and the send hangs/fails. DEFAULT_FROM_EMAIL MUST equal the authenticated mailbox
# (noreply@doctor.school) or Mail.ru rejects the From. URL-encode the app-pass
# (`urllib.parse.quote(pw, safe='')`); `@` in the username → `%40`.
EMAIL_URL=consolemail://
DEFAULT_FROM_EMAIL=glitchtip@doctor.school

# First-user registration: open by default so the owner registers the first account
# over the tunnel, then create the org + project (README). Close it afterwards:
#   ENABLE_USER_REGISTRATION=false
