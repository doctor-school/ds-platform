# /etc/ds-platform/zitadel.env — TEMPLATE (DSO-100 spec §5.4). Copy onto api-prod as
# /etc/ds-platform/zitadel.env, root:root 0600. NEVER commit real values. Consumed
# by the `zitadel` core container (compose/api-prod/compose.yml) via env_file. The
# non-secret externalisation (EXTERNALDOMAIN/PORT/SECURE, LoginV2, DB shape) is set
# in compose `environment:`; only secrets + the DB host live here.
#
# The `ds` DB password below MUST equal POSTGRES_PASSWORD in data.env and the DB
# password in api.env's DATABASE_URL (one Postgres role, `ds`).

# === Masterkey — encryption-at-rest key. EXACTLY 32 characters or Zitadel refuses
# to start. Generate:  openssl rand -hex 16
ZITADEL_MASTERKEY=<exactly-32-chars>

# === Database → data-prod PRIVATE VPC IP. Zitadel creates + owns the `zitadel`
# database itself on first boot using the admin creds (dev-stand parity).
ZITADEL_DATABASE_POSTGRES_HOST=192.168.0.10
ZITADEL_DATABASE_POSTGRES_USER_PASSWORD=<db-password>
ZITADEL_DATABASE_POSTGRES_ADMIN_PASSWORD=<db-password>

# === FIRST-BOOT bootstrap (spec §6.1 / README init step) ============================
# Read ONLY on a FRESH instance init (start-from-init on an empty `zitadel` DB). They
# create the ds-bootstrap machine user (+ PAT written to /pat/pat.txt on the tmpfs)
# and a console admin, and are otherwise inert. UNCOMMENT for the FIRST boot, capture
# the PAT (README), then COMMENT them back out so a restart never re-triggers init.
# ZITADEL_FIRSTINSTANCE_PATPATH=/pat/pat.txt
# ZITADEL_FIRSTINSTANCE_ORG_MACHINE_MACHINE_USERNAME=ds-bootstrap
# ZITADEL_FIRSTINSTANCE_ORG_MACHINE_MACHINE_NAME=ds-bootstrap
# ZITADEL_FIRSTINSTANCE_ORG_MACHINE_PAT_EXPIRATIONDATE=2099-12-31T23:59:59Z
# ZITADEL_FIRSTINSTANCE_ORG_HUMAN_USERNAME=zitadel-admin
# ZITADEL_FIRSTINSTANCE_ORG_HUMAN_PASSWORD=<console-admin-password>  # upper+lower+digit+symbol
# ZITADEL_FIRSTINSTANCE_ORG_HUMAN_PASSWORDCHANGEREQUIRED=false
#
# NOTE: the real SMTP provider (mail.ru) is configured by idp/provision.sh, NOT by
# this env — run provision.sh with the IDP_SMTP_REAL_* values from api.env sourced.
