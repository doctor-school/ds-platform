# DS Platform — local dev-stand environment template (PORTABLE CONTRACT)
#
# Copy this file to your personal overlay and fill in real values:
#   cp .env.example ~/.ds-platform/.env.local
#
# .env.local holds real secrets + recipe-specific endpoints and is gitignored.
# Full design: setup-design §4.1 (env-var contract) — see README.md for the link.

# === Docker host (recipe-specific) ===
# Tech Lead's recipe: leave empty — uses sudo-docker wrappers over ssh (user claude)
# Host-only recipe: leave empty
DOCKER_HOST=

# === DX-script transport (recipe-specific) — consumed by tools/dev/run.mjs ===
# DEV_SSH_HOST: ssh target for a recipe whose Docker daemon is on another box.
#   Empty -> host-only recipe; the launcher uses the local Docker daemon.
#   Tech Lead's TrueNAS Hybrid recipe: the `truenas` ~/.ssh/config alias.
DEV_SSH_HOST=
# DEV_DOCKER_SUDO: 1 -> prefix `sudo` to docker on the remote box. The shared
#   TrueNAS runs `sudo docker` — user `claude` is intentionally not in the
#   docker group (README -> Bootstrap checklist step 1).
DEV_DOCKER_SUDO=
# DEV_REMOTE_DIR: working dir on the remote box. `dev:up`, `dev:reset-db` and
#   `dev:config` sync infra/dev-stand/ there before running docker compose, so
#   the contract in git stays the single source of truth. This very file is also
#   shipped there as the compose `.env` on each sync, so its secrets reach the
#   remote stack automatically — no manual docker compose on the box. Must be a
#   plain absolute or ~/ path: no spaces, no "..", no shell metacharacters.
#   Default: ~/ds-platform-dev-stand
DEV_REMOTE_DIR=
# DEV_COMPOSE_OVERRIDE: path to the personal compose.override.yml. Optional —
#   defaults to ~/.ds-platform/compose.override.yml; ignored when absent.
DEV_COMPOSE_OVERRIDE=

# === Service endpoints (recipe-specific hostnames) ===
# Ports below are the setup-design defaults. Some collide with services already
# bound on a shared host (Postgres 5432, 8000, 8001) — see README -> Container
# isolation. On such a recipe, point these at the remapped host-side port in
# your .env.local (e.g. HOST:5442 for Postgres); the contract is recipe-agnostic.
DATABASE_URL=postgres://ds:CHANGE_ME@HOST:5432/ds_dev
REDIS_URL=redis://HOST:6379
S3_ENDPOINT=http://HOST:9000
S3_REGION=us-east-1
S3_BUCKET_UPLOADS=ds-uploads-dev
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=CHANGE_ME
# Zitadel publishes OIDC discovery at the root — the issuer is the bare origin,
# not a path. It MUST equal http://${IDP_EXTERNAL_DOMAIN}:${IDP_PORT}, i.e. the
# host:port clients reach (and what Zitadel advertises in discovery).
IDP_ISSUER=http://HOST:9080
# IDP_EXTERNAL_DOMAIN: the hostname Zitadel advertises in discovery URLs — set it
# to your recipe's HOST (truenas.local | localhost | a cloud VM). A mismatch
# makes every OIDC client reject the issuer. Default localhost (host-only recipe).
IDP_EXTERNAL_DOMAIN=localhost
# IDP_CLIENT_ID / IDP_CLIENT_SECRET come from idp/provision.sh (the OIDC app it
# creates), not at boot. IDP_CLIENT_ID is the numeric id Zitadel assigns, not the
# app name. The api binds the real Zitadel adapter on IDP_ISSUER + IDP_SERVICE_TOKEN
# (the org-owner PAT); the client_id/secret are the confidential-client creds the
# BFF presents at the token endpoint for the session->token exchange (EARS-8) +
# refresh rotation (EARS-9). Absent, those two paths fail closed (auth design §3,
# §11). See idp/bootstrap.md.
IDP_CLIENT_ID=CHANGE_ME
IDP_CLIENT_SECRET=CHANGE_ME
# OIDC redirect URI registered on the application — the token exchange echoes it.
# Must byte-match a redirect URI provision.sh registers on the app (it echoes the
# registered set on completion). This is the api BFF's OWN callback, and the api
# runs on your dev machine — so it is `localhost`, NOT your Zitadel HOST: keep it
# `localhost` even on the truenas.local recipe (a truenas.local value is not
# registered -> authorize 400, #159). Use :3100/auth/callback for the portal BFF.
IDP_REDIRECT_URI=http://localhost:3000/auth/callback
# Optional space-separated OIDC scopes; the adapter defaults to
# "openid profile offline_access urn:zitadel:iam:org:project:roles" when unset.
# IDP_SCOPES=
# IDP_SERVICE_TOKEN: org-owner PAT for the ds-bootstrap machine user. Minted by
# the FIRSTINSTANCE bootstrap; keep it in a gitignored file, never here.
IDP_SERVICE_TOKEN=CHANGE_ME
# IDP_BOOTSTRAP: set to 1 ONLY during a Zitadel re-init so start-from-init creates
# the ds-bootstrap machine user + console admin.
# Leave empty for normal boots. IDP_BOOTSTRAP_ADMIN_PASSWORD is the console admin
# password, read only on a bootstrap init (dev-only, trusted LAN). See
# idp/bootstrap.md. IDP_LOGIN_V2_REQUIRED enables the Zitadel v2 login feature on
# the instance — REQUIRED for the headless BFF session->token exchange (EARS-8):
# the /v2/oidc/auth_requests/{id} session-link API only resolves an auth request
# created under Login V2. Defaults true; do not disable it.
IDP_BOOTSTRAP=
IDP_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME
IDP_LOGIN_V2_REQUIRED=true
# === API security secrets ===
# AUDIT_IDENTIFIER_PEPPER: server-side HMAC pepper the BFF keys the audit_ledger
# identifier_hash with (#141, ADR-0001 §7 / ADR-0003 §6). A bare digest over a
# low-entropy identifier space (emails / phones) is a reproducible existence
# oracle; HMAC keyed by this secret is not. The api fails closed at boot when it
# is unset in a non-test runtime — set it for any dev-stand that runs the api
# (the VITEST e2e suite uses a fixed test pepper, so CI needs nothing here).
# Generate e.g. `openssl rand -hex 32`.
AUDIT_IDENTIFIER_PEPPER=CHANGE_ME
CENTRIFUGO_URL=http://HOST:8000
CENTRIFUGO_API_KEY=CHANGE_ME
CERBOS_URL=http://HOST:3592
SMTP_HOST=HOST
SMTP_PORT=1025

# === Delivery mode flags (#176) — dev sinks (default) vs REAL providers ===
# Zitadel's email + SMS providers are switchable between the free dev sinks and
# the real production providers, the env-flag precedent of apps/api's
# BOT_PROTECTION_ENABLED. idp/provision.sh reads these and CONVERGES the active
# provider on every run — flip a flag, re-run provision.sh, and delivery
# re-points (idempotent: same mode = "no changes").
#   EMAIL_DELIVERY_MODE = mailpit (default; routes to the local Mailpit catch-all)
#                       | real    (routes to the real transactional sender below)
#   SMS_DELIVERY_MODE   = sink    (default; routes to the local sms-sink catch-all)
#                       | real    (routes to sms-aero-adapter -> SMS-Aero)
# REAL SMS COSTS MONEY — that is why SMS defaults to the free `sink` and the real
# route is opt-in, exercised by one supervised paid test only. Email `real` is
# free-ish (your transactional provider's normal volume) but still off by default
# so the dev-stand never emails real inboxes unintentionally.
EMAIL_DELIVERY_MODE=mailpit
SMS_DELIVERY_MODE=sink
# Real-SMTP creds — used ONLY when EMAIL_DELIVERY_MODE=real. Uncomment + fill in
# your transactional sender (e.g. Beget SMTP, a provider relay). TLS is forced on
# by provision.sh; an unset required var makes provision.sh fail loudly rather
# than silently fall back to Mailpit. IDP_SMTP_REAL_HOST may carry the port
# (host:port) or you may set IDP_SMTP_REAL_PORT separately. NEVER commit real
# values — they belong in your gitignored .env.local only.
# IDP_SMTP_REAL_HOST=CHANGE_ME
# IDP_SMTP_REAL_PORT=587
# IDP_SMTP_REAL_USER=CHANGE_ME
# IDP_SMTP_REAL_PASSWORD=CHANGE_ME
# IDP_SMTP_REAL_SENDER_ADDRESS=CHANGE_ME
# IDP_SMTP_REAL_SENDER_NAME=DS Platform
# SMS-Aero (smsaero.ru Gate API v2) creds — used ONLY when SMS_DELIVERY_MODE=real,
# consumed by the sms-aero-adapter service (compose.core.yml). In PRODUCTION these
# live ONLY in Beget `~/.env` and must NEVER be committed; on the dev-stand the
# operator copies them into the gitignored .env.local for the one supervised paid
# test, then removes them / flips SMS_DELIVERY_MODE back to `sink`. SMSAERO_SIGN
# defaults to the unmoderated "SMS Aero" sender available to new RU accounts.
# SMSAERO_EMAIL=CHANGE_ME
# SMSAERO_API_KEY=CHANGE_ME
# SMSAERO_SIGN=SMS Aero

# === Feature flags (Unleash, #184) ===
# Unleash self-hosted serves the admin UI + the flag APIs the api/portal SDKs call.
# Deploy-only here; the SDK wiring + env-flag migration is the follow-up (#185).
#   UNLEASH_URL — the API base the SDKs consume (note the /api suffix; the bare
#     origin http://<HOST>:4242 is the admin UI). Set <HOST> to your recipe's host.
UNLEASH_URL=http://HOST:4242/api
# API tokens SEEDED into Unleash at boot (compose INIT_*_API_TOKENS). Format:
#   client/server : *:development.<random-hex>  (backend SDK — the api uses this)
#   frontend      : *:development.<random-hex>  (the portal uses this)
# These are SECRETS — real values live ONLY in ~/.ds-platform/.env.local (dev) and
# Beget ~/.env (prod) → Vault later; NEVER commit them. Generate distinct hex
# secrets, e.g. `openssl rand -hex 32`, and prefix with `*:development.`. Leave as
# CHANGE_ME to start Unleash without pre-seeded tokens (mint them in the UI instead).
UNLEASH_INIT_CLIENT_API_TOKEN=CHANGE_ME
UNLEASH_INIT_FRONTEND_API_TOKEN=CHANGE_ME

# === Data volume root (recipe-specific) ===
# Tech Lead's TrueNAS recipe: DS_DATA_PATH=/mnt/Daily/dev
# Host-only recipe (named volumes): leave empty -> compose uses named volumes
DS_DATA_PATH=

# === Host port overrides (recipe-specific) ===
# compose.core.yml publishes each service on ${<SVC>_PORT:-<default>}. Leave a
# var unset to use the setup-design default below. Override it only when the
# default port is already bound on your Docker host — see README -> Container
# isolation (on the reference TrueNAS box Postgres 5432 / 8000 / 8001 collide,
# so that recipe sets POSTGRES_PORT=5442 and CENTRIFUGO_PORT=8100).
# The container-side port never changes; only the host side is remapped.
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
CENTRIFUGO_PORT=8000
CERBOS_HTTP_PORT=3592
CERBOS_GRPC_PORT=3593
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
# sms-sink — the dev SMS catch-all (SMS analogue of Mailpit). Zitadel's HTTP SMS
# provider posts outbound SMS here; the live SMS-OTP e2e reads codes back on this
# published host port (SMS_SINK_URL, default http://<HOST>:8090). See idp/bootstrap.md.
SMS_SINK_PORT=8090
# sms-aero-adapter — the REAL outbound SMS route (opt-in, used only when
# SMS_DELIVERY_MODE=real). Zitadel POSTs outbound SMS here on the bridge
# (sms-aero-adapter:8091) and the adapter forwards to SMS-Aero; the host port is
# only for operator poking. Harmless when unused. See idp/bootstrap.md §3.bis.
SMS_AERO_ADAPTER_PORT=8091
# IDP_PORT must agree with IDP_EXTERNAL_DOMAIN and IDP_ISSUER above — together
# they form the host:port Zitadel advertises in OIDC discovery.
IDP_PORT=9080
# Unleash — runtime feature-flag service + admin UI (#184). 4242 is free on the
# reference box. The admin UI is published here (http://<HOST>:4242).
UNLEASH_PORT=4242

# === Compose-side secrets ===
POSTGRES_PASSWORD=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME
# IDP_SECRET_KEY is Zitadel's masterkey (encryption-at-rest) — it MUST be exactly
# 32 characters or the service refuses to start. Generate e.g. `openssl rand -hex 16`.
IDP_SECRET_KEY=CHANGE_ME
