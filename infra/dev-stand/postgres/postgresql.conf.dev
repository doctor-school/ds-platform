# DS Platform dev-stand — Postgres 17 dev tuning (PORTABLE CONTRACT)
#
# Loaded via: postgres -c config_file=/etc/postgresql/postgresql.conf
# Values target a ~4-8 GB working set on a developer box — NOT production.
# Production tuning is owned by the prod-deploy infra, a separate concern.

# --- Extensions / background workers ---
# pg_partman background worker (ADR-0003 §3 — partition auto-creation runs INSIDE
# Postgres via the BGW, not an external cron). The partman BINARY ships in the
# data-layer image (Dockerfile), shared by dev AND prod; the GUCs below are
# PER-ENV — prod sets the equivalent values (its own dbname/role/interval) in the
# prod data-layer conf. `pg_partman_bgw.dbname` must be the app database (ds_dev
# here) and `.role` the owner of the `partman` schema (ds). The worker calls
# partman.run_maintenance on its interval, extending the monthly audit_ledger
# chain ~premake months ahead. Loading the library requires a restart.
shared_preload_libraries = 'pg_partman_bgw'
pg_partman_bgw.dbname = 'ds_dev'
pg_partman_bgw.role = 'ds'
# 3600s = hourly — ample for a monthly interval on a power-cycled dev box.
pg_partman_bgw.interval = 3600

# --- Connections ---
listen_addresses = '*'
max_connections = 100

# hba_file / ident_file must point back into PGDATA: with config_file outside
# PGDATA they would otherwise default next to this file and not be found
# (the official postgres entrypoint generates them inside PGDATA).
hba_file = '/var/lib/postgresql/data/pg_hba.conf'
ident_file = '/var/lib/postgresql/data/pg_ident.conf'

# --- Memory ---
shared_buffers = 512MB
effective_cache_size = 2GB
work_mem = 16MB
maintenance_work_mem = 256MB

# --- Write-ahead log ---
wal_level = replica
max_wal_size = 2GB
min_wal_size = 256MB
checkpoint_completion_target = 0.9

# --- Planner (SSD / ZFS-backed storage) ---
random_page_cost = 1.1
effective_io_concurrency = 200

# --- Logging (verbose for dev diagnostics) ---
log_min_duration_statement = 200ms
log_connections = on
log_disconnections = on
log_line_prefix = '%m [%p] %q%u@%d '

# --- Timezone ---
timezone = 'UTC'
