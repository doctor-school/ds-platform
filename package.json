{
  "name": "ds-platform",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "description": "Doctor.School Platform monorepo",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.7.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "bootstrap": "tsx tools/agent-bootstrap.ts",
    "lint:endpoint-authz": "tsx --tsconfig apps/api/tsconfig.json tools/lint/endpoint-authz-lint.ts",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "eslint . && turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "prepare": "simple-git-hooks",
    "dev:up": "node tools/dev/run.mjs up",
    "dev:down": "node tools/dev/run.mjs down",
    "dev:logs": "node tools/dev/run.mjs logs",
    "dev:restart": "node tools/dev/run.mjs restart",
    "dev:psql": "node tools/dev/run.mjs psql",
    "dev:snapshot": "node tools/dev/run.mjs snapshot",
    "dev:rollback": "node tools/dev/run.mjs rollback",
    "dev:reset-db": "node tools/dev/run.mjs reset-db",
    "dev:status": "node tools/dev/run.mjs status",
    "dev:config": "node tools/dev/run.mjs config",
    "dev:smoke": "node tools/dev/smoke.mjs"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "execa": "^9.6.1",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "lint-staged": "^17.0.7",
    "pg": "^8.13.0",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.22.4",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix"
    ],
    "*.{md,json,yaml,yml,css}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "esbuild",
      "simple-git-hooks"
    ]
  }
}
