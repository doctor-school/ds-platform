    "./button": "./src/primitives/button.tsx",
    "./link": "./src/primitives/link.tsx",
    "./input": "./src/primitives/input.tsx",
    "./label": "./src/primitives/label.tsx",
    "./card": "./src/primitives/card.tsx",
    "./form": "./src/primitives/form.tsx",
    "./input-otp": "./src/primitives/input-otp.tsx",
    "./tabs": "./src/primitives/tabs.tsx",
    "./fields": "./src/primitives/fields/index.ts",
