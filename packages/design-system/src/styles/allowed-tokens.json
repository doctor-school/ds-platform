  "descriptions": {
    "--font-family-base": "Brand UI base font (brand → token map §2): Inter — all portal UI, body + headings. Inter is web-available + the shadcn default → no fallback risk. The portal loads Inter via next/font and binds it to --font-sans, so utilities resolve to Inter.",
    "--font-family-sans": "Alias of font.family.base — the Tailwind `font-sans` utility / body default resolves to the brand base font (Inter).",
    "--font-family-display": "RESERVED — Tactic Sans Extended (brand: special/marketing surfaces). Licensed brand face; NOT loaded by core UI. Token only.",
    "--font-family-brand": "RESERVED — Century Gothic (brand: project logos/lockups). Licensed brand face; NOT loaded by core UI. Token only.",
    "--font-family-social": "RESERVED — Montserrat (brand: social-media assets). NOT loaded by core UI. Token only.",
    "--color-background": "The default page/app surface. Pair with `foreground` for text.",
    "--color-foreground": "Default text and icon colour, used on `background`.",
    "--color-card": "A raised surface (card, popover, panel) sitting on `background`. Pair with `card-foreground`.",
    "--color-card-foreground": "Text and icon colour on a `card` surface.",
    "--color-primary": "Brand anchor (blue.500) for link text, focus accents, icons and tints. NOT a normal-weight filled action — that fails AA; use `primary-action`.",
    "--color-primary-foreground": "Text and icon colour ON a primary/action fill (white on the brand button).",
    "--color-primary-action": "Resting fill for a normal-weight filled primary button (blue.700, AA on white). Pairs with `primary-foreground`.",
    "--color-primary-hover": "Hover fill for a primary action (darker than the resting `primary-action`).",
    "--color-primary-pressed": "Pressed/active fill for a primary action.",
    "--color-primary-surface": "Brand-coloured panel/surface that carries normal-weight white copy (e.g. the auth brand panel).",
    "--color-secondary": "Low-emphasis tonal fill (secondary buttons, subtle chips). Pair with `secondary-foreground`.",
    "--color-secondary-foreground": "Text and icon colour on a `secondary` fill.",
    "--color-muted": "A muted background for subtle fills, hovered rows or disabled tracks.",
    "--color-muted-foreground": "De-emphasised text — helper text, placeholders, captions, metadata.",
    "--color-accent": "Hover/selected background for interactive list items and ghost buttons. Pair with `accent-foreground`.",
    "--color-accent-foreground": "Text and icon colour on an `accent` surface.",
    "--color-success": "Positive-status fill, border or icon. Pair with `success-foreground`.",
    "--color-success-foreground": "Text and icon colour on a `success` fill.",
    "--color-warning": "Caution-status fill, border or icon. Pair with `warning-foreground`.",
    "--color-warning-foreground": "Text and icon colour on a `warning` fill.",
    "--color-destructive": "Error/danger fill, border or icon — destructive actions and invalid state. Pair with `destructive-foreground`.",
    "--color-destructive-foreground": "Text and icon colour on a `destructive` fill.",
    "--color-border": "Default border and divider colour on surfaces.",
    "--color-input": "Border colour of form inputs and controls.",
    "--color-ring": "The keyboard-focus ring colour (the `focus-visible` ring on every interactive primitive)."
  }
}
