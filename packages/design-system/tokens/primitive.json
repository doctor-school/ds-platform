{
  "color": {
    "$type": "color",
    "white": { "$value": "oklch(1 0 0)" },
    "black": { "$value": "oklch(0 0 0)" },
    "neutral": {
      "0": { "$value": "oklch(1 0 0)" },
      "50": { "$value": "oklch(0.985 0 0)" },
      "100": { "$value": "oklch(0.97 0 0)" },
      "200": { "$value": "oklch(0.922 0 0)" },
      "400": { "$value": "oklch(0.708 0 0)" },
      "500": { "$value": "oklch(0.556 0 0)" },
      "700": { "$value": "oklch(0.269 0 0)" },
      "800": { "$value": "oklch(0.205 0 0)" },
      "950": { "$value": "oklch(0.145 0 0)" },
      "alpha-10": { "$value": "oklch(1 0 0 / 10%)" },
      "alpha-15": { "$value": "oklch(1 0 0 / 15%)" }
    },
    "red": {
      "500": { "$value": "oklch(0.577 0.245 27.325)" },
      "400": { "$value": "oklch(0.704 0.191 22.216)" }
    }
  },

  "font": {
    "family": {
      "$type": "fontFamily",
      "sans": {
        "$value": [
          "ui-sans-serif",
          "system-ui",
          "sans-serif",
          "Apple Color Emoji",
          "Segoe UI Emoji",
          "Segoe UI Symbol",
          "Noto Color Emoji"
        ]
      },
      "mono": {
        "$value": [
          "ui-monospace",
          "SFMono-Regular",
          "Menlo",
          "Monaco",
          "Consolas",
          "Liberation Mono",
          "Courier New",
          "monospace"
        ]
      }
    },
    "size": {
      "$type": "dimension",
      "xs": { "$value": "0.75rem" },
      "sm": { "$value": "0.875rem" },
      "base": { "$value": "1rem" },
      "lg": { "$value": "1.125rem" },
      "xl": { "$value": "1.25rem" },
      "2xl": { "$value": "1.5rem" },
      "3xl": { "$value": "1.875rem" },
      "4xl": { "$value": "2.25rem" }
    },
    "weight": {
      "$type": "fontWeight",
      "normal": { "$value": 400 },
      "medium": { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold": { "$value": 700 }
    },
    "line-height": {
      "$type": "number",
      "none": { "$value": 1 },
      "tight": { "$value": 1.25 },
      "snug": { "$value": 1.375 },
      "normal": { "$value": 1.5 },
      "relaxed": { "$value": 1.625 }
    },
    "letter-spacing": {
      "$type": "dimension",
      "tight": { "$value": "-0.025em" },
      "normal": { "$value": "0em" },
      "wide": { "$value": "0.025em" }
    }
  },

  "space": {
    "$type": "dimension",
    "0": { "$value": "0rem" },
    "px": { "$value": "1px" },
    "0-5": { "$value": "0.125rem" },
    "1": { "$value": "0.25rem" },
    "1-5": { "$value": "0.375rem" },
    "2": { "$value": "0.5rem" },
    "2-5": { "$value": "0.625rem" },
    "3": { "$value": "0.75rem" },
    "4": { "$value": "1rem" },
    "5": { "$value": "1.25rem" },
    "6": { "$value": "1.5rem" },
    "8": { "$value": "2rem" },
    "10": { "$value": "2.5rem" },
    "12": { "$value": "3rem" },
    "16": { "$value": "4rem" }
  },

  "radius": {
    "$type": "dimension",
    "base": { "$value": "0.625rem" }
  },

  "border-width": {
    "$type": "dimension",
    "0": { "$value": "0px" },
    "1": { "$value": "1px" },
    "2": { "$value": "2px" },
    "4": { "$value": "4px" }
  },

  "shadow": {
    "$type": "shadow",
    "sm": { "$value": "0 1px 2px 0 oklch(0 0 0 / 0.05)" },
    "base": {
      "$value": "0 1px 3px 0 oklch(0 0 0 / 0.1), 0 1px 2px -1px oklch(0 0 0 / 0.1)"
    },
    "md": {
      "$value": "0 4px 6px -1px oklch(0 0 0 / 0.1), 0 2px 4px -2px oklch(0 0 0 / 0.1)"
    },
    "lg": {
      "$value": "0 10px 15px -3px oklch(0 0 0 / 0.1), 0 4px 6px -4px oklch(0 0 0 / 0.1)"
    }
  },

  "duration": {
    "$type": "duration",
    "fast": { "$value": "150ms" },
    "base": { "$value": "200ms" },
    "slow": { "$value": "300ms" }
  },

  "easing": {
    "$type": "cubicBezier",
    "standard": { "$value": [0.4, 0, 0.2, 1] },
    "in": { "$value": [0.4, 0, 1, 1] },
    "out": { "$value": [0, 0, 0.2, 1] }
  },

  "z-index": {
    "$type": "number",
    "base": { "$value": 0 },
    "dropdown": { "$value": 1000 },
    "sticky": { "$value": 1100 },
    "overlay": { "$value": 1200 },
    "modal": { "$value": 1300 },
    "popover": { "$value": 1400 },
    "toast": { "$value": 1500 }
  },

  "opacity": {
    "$type": "number",
    "0": { "$value": 0 },
    "50": { "$value": 0.5 },
    "80": { "$value": 0.8 },
    "90": { "$value": 0.9 },
    "100": { "$value": 1 }
  },

  "breakpoint": {
    "$type": "dimension",
    "sm": { "$value": "40rem" },
    "md": { "$value": "48rem" },
    "lg": { "$value": "64rem" },
    "xl": { "$value": "80rem" },
    "2xl": { "$value": "96rem" }
  }
}
