{
  "color": {
    "$type": "color",
    "$description": "Brand-pinned colors carry exact brand-book hexes (Doctor School brand → token map §1.1). System-derived values (neutral ramp, intermediate blue stops, introduced red) are noted inline. Reserved accent palettes (§1.2) have no semantic role.",
    "white": { "$value": "#FFFFFF" },
    "black": { "$value": "oklch(0 0 0)" },

    "blue": {
      "$description": "Brand primary family. 700/500/300 are brand-pinned anchors (Pantone Dark Blue C / 2727 C / 284 C). 100/200/400/600/800 are system-derived around the anchors for tints/hover/pressed.",
      "100": { "$value": "#D3E8FD" },
      "200": { "$value": "#AED4FB" },
      "300": { "$value": "#6BB1F7" },
      "400": { "$value": "#4C9BF5" },
      "500": { "$value": "#2D84F2" },
      "600": { "$value": "#1F69C8" },
      "700": { "$value": "#114D9E" },
      "800": { "$value": "#0D3A77" }
    },

    "green": {
      "$description": "Brand status green (success). 500 is brand-pinned; darker stop reserved via accent.green.",
      "500": { "$value": "#009959" }
    },

    "orange": {
      "$description": "Brand status orange/terracotta (warning). 500 is brand-pinned.",
      "500": { "$value": "#DF5726" }
    },

    "neutral": {
      "$description": "System-derived blue-tinted gray ramp (cool hue ~250 around the brand primary), replacing the pure-gray #233 ramp. L values track Tailwind's gray scale; chroma is kept low so it reads as a cool neutral.",
      "0": { "$value": "oklch(1 0 0)" },
      "50": { "$value": "oklch(0.985 0.002 250)" },
      "100": { "$value": "oklch(0.968 0.004 250)" },
      "200": { "$value": "oklch(0.922 0.006 250)" },
      "300": { "$value": "oklch(0.87 0.008 250)" },
      "400": { "$value": "oklch(0.704 0.01 250)" },
      "500": { "$value": "oklch(0.556 0.012 250)" },
      "600": { "$value": "oklch(0.45 0.014 250)" },
      "700": { "$value": "oklch(0.372 0.016 250)" },
      "800": { "$value": "oklch(0.27 0.018 250)" },
      "900": { "$value": "oklch(0.21 0.02 250)" },
      "950": { "$value": "oklch(0.16 0.02 250)" },
      "alpha-10": { "$value": "oklch(1 0 0 / 10%)" },
      "alpha-15": { "$value": "oklch(1 0 0 / 15%)" }
    },

    "red": {
      "$description": "INTRODUCED functional error red — the Doctor School brand defines none. #C81E1E carries white text at 5.74:1 (WCAG AA pass for normal text) and reads against white. System-tunable.",
      "500": { "$value": "#C81E1E" },
      "400": { "$value": "#E15555" }
    },

    "accent": {
      "$description": "RESERVED brand accent palettes (brand → token map §1.2). Tokenised as primitive reserves for future category/gamification surfaces; NO semantic role in this foundation. Out of scope for the auth slice.",
      "purple": {
        "300": { "$value": "#D3BADE" },
        "500": { "$value": "#9257AE" },
        "700": { "$value": "#73428A" }
      },
      "orange": {
        "300": { "$value": "#F2BAA6" },
        "500": { "$value": "#DF5726" },
        "700": { "$value": "#B2431A" }
      },
      "gold": {
        "300": { "$value": "#EFD8A9" },
        "500": { "$value": "#E4BC6C" },
        "700": { "$value": "#C5963A" }
      },
      "green": {
        "300": { "$value": "#009959" },
        "500": { "$value": "#00693D" },
        "700": { "$value": "#00331E" }
      },
      "lime": {
        "300": { "$value": "#BDD631" },
        "500": { "$value": "#70C143" }
      },
      "lavender": {
        "500": { "$value": "#B2A4D4" }
      },
      "sky": {
        "500": { "$value": "#48A4DB" }
      }
    }
  },

  "font": {
    "family": {
      "$type": "fontFamily",
      "base": {
        "$description": "Brand UI base font (brand → token map §2): Inter — all portal UI, body + headings. Inter is web-available + the shadcn default → no fallback risk. The portal loads Inter via next/font and binds it to --font-sans, so utilities resolve to Inter.",
        "$value": [
          "Inter",
          "ui-sans-serif",
          "system-ui",
          "sans-serif",
          "Apple Color Emoji",
          "Segoe UI Emoji",
          "Segoe UI Symbol",
          "Noto Color Emoji"
        ]
      },
      "sans": {
        "$description": "Alias of font.family.base — the Tailwind `font-sans` utility / body default resolves to the brand base font (Inter).",
        "$value": [
          "Inter",
          "ui-sans-serif",
          "system-ui",
          "sans-serif",
          "Apple Color Emoji",
          "Segoe UI Emoji",
          "Segoe UI Symbol",
          "Noto Color Emoji"
        ]
      },
      "display": {
        "$description": "RESERVED — Tactic Sans Extended (brand: special/marketing surfaces). Licensed brand face; NOT loaded by core UI. Token only.",
        "$value": ["Tactic Sans Extended", "Inter", "sans-serif"]
      },
      "brand": {
        "$description": "RESERVED — Century Gothic (brand: project logos/lockups). Licensed brand face; NOT loaded by core UI. Token only.",
        "$value": ["Century Gothic", "Inter", "sans-serif"]
      },
      "social": {
        "$description": "RESERVED — Montserrat (brand: social-media assets). NOT loaded by core UI. Token only.",
        "$value": ["Montserrat", "Inter", "sans-serif"]
      },
      "mono": {
        "$value": [
          "ui-monospace",
          "SFMono-Regular",
          "Menlo",
          "Monaco",
          "Consolas",
          "Liberation Mono",
          "Courier New",
          "monospace"
        ]
      }
    },
    "size": {
      "$type": "dimension",
      "xs": { "$value": "0.75rem" },
      "sm": { "$value": "0.875rem" },
      "base": { "$value": "1rem" },
      "lg": { "$value": "1.125rem" },
      "xl": { "$value": "1.25rem" },
      "2xl": { "$value": "1.5rem" },
      "3xl": { "$value": "1.875rem" },
      "4xl": { "$value": "2.25rem" }
    },
    "weight": {
      "$type": "fontWeight",
      "normal": { "$value": 400 },
      "medium": { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold": { "$value": 700 }
    },
    "line-height": {
      "$type": "number",
      "none": { "$value": 1 },
      "tight": { "$value": 1.25 },
      "snug": { "$value": 1.375 },
      "normal": { "$value": 1.5 },
      "relaxed": { "$value": 1.625 }
    },
    "letter-spacing": {
      "$type": "dimension",
      "tight": { "$value": "-0.025em" },
      "normal": { "$value": "0em" },
      "wide": { "$value": "0.025em" }
    }
  },

  "space": {
    "$type": "dimension",
    "0": { "$value": "0rem" },
    "px": { "$value": "1px" },
    "0-5": { "$value": "0.125rem" },
    "1": { "$value": "0.25rem" },
    "1-5": { "$value": "0.375rem" },
    "2": { "$value": "0.5rem" },
    "2-5": { "$value": "0.625rem" },
    "3": { "$value": "0.75rem" },
    "4": { "$value": "1rem" },
    "5": { "$value": "1.25rem" },
    "6": { "$value": "1.5rem" },
    "8": { "$value": "2rem" },
    "10": { "$value": "2.5rem" },
    "12": { "$value": "3rem" },
    "16": { "$value": "4rem" }
  },

  "radius": {
    "$type": "dimension",
    "base": { "$value": "0.625rem" }
  },

  "border-width": {
    "$type": "dimension",
    "0": { "$value": "0px" },
    "1": { "$value": "1px" },
    "2": { "$value": "2px" },
    "4": { "$value": "4px" }
  },

  "shadow": {
    "$type": "shadow",
    "sm": { "$value": "0 1px 2px 0 oklch(0 0 0 / 0.05)" },
    "base": {
      "$value": "0 1px 3px 0 oklch(0 0 0 / 0.1), 0 1px 2px -1px oklch(0 0 0 / 0.1)"
    },
    "md": {
      "$value": "0 4px 6px -1px oklch(0 0 0 / 0.1), 0 2px 4px -2px oklch(0 0 0 / 0.1)"
    },
    "lg": {
      "$value": "0 10px 15px -3px oklch(0 0 0 / 0.1), 0 4px 6px -4px oklch(0 0 0 / 0.1)"
    }
  },

  "duration": {
    "$type": "duration",
    "fast": { "$value": "150ms" },
    "base": { "$value": "200ms" },
    "slow": { "$value": "300ms" }
  },

  "easing": {
    "$type": "cubicBezier",
    "standard": { "$value": [0.4, 0, 0.2, 1] },
    "in": { "$value": [0.4, 0, 1, 1] },
    "out": { "$value": [0, 0, 0.2, 1] }
  },

  "z-index": {
    "$type": "number",
    "base": { "$value": 0 },
    "dropdown": { "$value": 1000 },
    "sticky": { "$value": 1100 },
    "overlay": { "$value": 1200 },
    "modal": { "$value": 1300 },
    "popover": { "$value": 1400 },
    "toast": { "$value": 1500 }
  },

  "opacity": {
    "$type": "number",
    "0": { "$value": 0 },
    "50": { "$value": 0.5 },
    "80": { "$value": 0.8 },
    "90": { "$value": 0.9 },
    "100": { "$value": 1 }
  },

  "breakpoint": {
    "$type": "dimension",
    "sm": { "$value": "40rem" },
    "md": { "$value": "48rem" },
    "lg": { "$value": "64rem" },
    "xl": { "$value": "80rem" },
    "2xl": { "$value": "96rem" }
  }
}
