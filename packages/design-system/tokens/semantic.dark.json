    "$type": "color",
    "background": { "$value": "{color.neutral.950}" },
    "foreground": { "$value": "{color.neutral.50}" },
    "card": { "$value": "{color.neutral.800}" },
    "card-foreground": { "$value": "{color.neutral.50}" },
    "primary": { "$value": "{color.neutral.50}" },
    "primary-foreground": { "$value": "{color.neutral.800}" },
    "secondary": { "$value": "{color.neutral.700}" },
    "secondary-foreground": { "$value": "{color.neutral.50}" },
    "muted": { "$value": "{color.neutral.700}" },
    "muted-foreground": { "$value": "{color.neutral.400}" },
    "accent": { "$value": "{color.neutral.700}" },
    "accent-foreground": { "$value": "{color.neutral.50}" },
    "destructive": { "$value": "{color.red.400}" },
    "destructive-foreground": { "$value": "{color.neutral.50}" },
    "border": { "$value": "{color.neutral.alpha-10}" },
    "input": { "$value": "{color.neutral.alpha-15}" },
    "ring": { "$value": "{color.neutral.500}" }
  }
