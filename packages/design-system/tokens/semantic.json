{
  "color": {
    "$type": "color",
    "$description": "Semantic roles repointed onto the Doctor School brand (brand → token map §1.3). Light-first; the .dark overrides live in semantic.dark.json. Brand primary = blue.500 #2D84F2; status = brand green/orange + introduced red.",
    "background": { "$value": "{color.white}" },
    "foreground": { "$value": "{color.neutral.900}" },
    "card": { "$value": "{color.white}" },
    "card-foreground": { "$value": "{color.neutral.900}" },
    "primary": { "$value": "{color.blue.500}" },
    "primary-foreground": { "$value": "{color.white}" },
    "primary-hover": { "$value": "{color.blue.700}" },
    "primary-pressed": { "$value": "{color.blue.700}" },
    "brand": { "$value": "{color.blue.700}" },
    "brand-foreground": { "$value": "{color.white}" },
    "secondary": { "$value": "{color.neutral.100}" },
    "secondary-foreground": { "$value": "{color.neutral.900}" },
    "muted": { "$value": "{color.neutral.100}" },
    "muted-foreground": { "$value": "{color.neutral.500}" },
    "accent": { "$value": "{color.neutral.100}" },
    "accent-foreground": { "$value": "{color.neutral.900}" },
    "success": { "$value": "{color.green.500}" },
    "success-foreground": { "$value": "{color.white}" },
    "warning": { "$value": "{color.orange.500}" },
    "warning-foreground": { "$value": "{color.white}" },
    "destructive": { "$value": "{color.red.500}" },
    "destructive-foreground": { "$value": "{color.white}" },
    "border": { "$value": "{color.neutral.200}" },
    "input": { "$value": "{color.neutral.200}" },
    "ring": { "$value": "{color.blue.300}" }
  },

  "radius": {
    "$type": "dimension",
    "control": { "$value": "{radius.base}" }
  },

  "text": {
    "body": {
      "font-size": { "$type": "dimension", "$value": "{font.size.base}" },
      "line-height": {
        "$type": "number",
        "$value": "{font.line-height.normal}"
      },
      "font-weight": { "$type": "fontWeight", "$value": "{font.weight.normal}" }
    },
    "heading": {
      "font-size": { "$type": "dimension", "$value": "{font.size.2xl}" },
      "line-height": {
        "$type": "number",
        "$value": "{font.line-height.tight}"
      },
      "font-weight": {
        "$type": "fontWeight",
        "$value": "{font.weight.semibold}"
      }
    },
    "label": {
      "font-size": { "$type": "dimension", "$value": "{font.size.sm}" },
      "line-height": {
        "$type": "number",
        "$value": "{font.line-height.normal}"
      },
      "font-weight": { "$type": "fontWeight", "$value": "{font.weight.medium}" }
    }
  },

  "motion": {
    "duration": {
      "$type": "duration",
      "fast": { "$value": "{duration.fast}" },
      "base": { "$value": "{duration.base}" }
    },
    "easing": {
      "$type": "cubicBezier",
      "standard": { "$value": "{easing.standard}" }
    }
  }
}
