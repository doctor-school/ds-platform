{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "noEmit": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    // The field primitives (#197) + auth blocks (#235/#227) are shadcn-derived,
    // owned UI code: they spread partial RHF props and forward optional callbacks
    // straight into third-party widgets (input-otp), patterns that legitimately pass
    // `prop: T | undefined` where the target types the prop as present-but-optional.
    // These two flags were already relaxed in `apps/portal/tsconfig.json` (where this
    // field code lived before the #235 move), so mirroring them keeps the verbatim
    // move behavior-identical instead of rewriting verified primitives to satisfy a
    // strictness the consuming app never enforced. Token/runtime safety is unaffected.
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": false,
    // jsdom component tests use jest-dom matchers (`toBeInTheDocument`, …) and the
    // Vitest globals (`describe`/`it`/`expect`); declare both so `tsc --noEmit` sees
    // the matcher + global augmentations the same way the runtime setup wires them.
    "types": ["vitest/globals", "@testing-library/jest-dom"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
