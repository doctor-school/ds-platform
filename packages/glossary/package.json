{
  "name": "@ds/glossary",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "description": "Canonical glossary ids + i18n label bundles — generated from apps/docs/content/product/glossary (ADR-0006 §6.2). GENERATED artifacts; do not edit by hand.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./ids": {
      "types": "./dist/ids.d.ts",
      "default": "./dist/ids.js"
    },
    "./messages/*": "./messages/*"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "messages"
  ],
  "scripts": {
    "generate": "tsx scripts/generate.ts",
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "devDependencies": {
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3"
  }
}
